    "url": "https://github.com/Danielrbrito07/portfolio-qa-daniel/issues"
  },
  "homepage": "https://github.com/Danielrbrito07/portfolio-qa-daniel#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.4.0"
  },
  "dependencies": {
    "dotenv": "^17.3.1"
  }
